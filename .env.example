# Glue RPC API key used in X-Api-Key header
RPC_API_KEY=your-rpc-api-key

# Foundry picks this up for all RPC requests
# Format: Header-Name:HeaderValue
ETH_RPC_HEADERS=X-Api-Key:your-rpc-api-key

# Deployment signer (do not commit real key values)
PRIVATE_KEY=your-private-key

# Deployed contract addresses
REWARD_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000
GAS_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000

# Admin target for add/remove admin scripts
ADMIN_ADDRESS=0x0000000000000000000000000000000000000000

# New owner for update owner scripts
OWNER_ADDRESS=0x0000000000000000000000000000000000000000
